# LLM
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
IMAGE_CACHE_MAX_GB=50
IMAGE_CACHE_MAX_AGE_DAYS=30
CONTAINER_MEMORY_LIMIT=16g
CONTAINER_CPU_LIMIT=8
EXECUTION_TIMEOUT_SECONDS=3600

# Data
DATA_CACHE_DIR=/data/datasets
GEO_MIRROR=https://ftp.ncbi.nlm.nih.gov/geo/
GDC_API=https://api.gdc.cancer.gov

# Self-hosted data mirror (optional — speeds up large downloads)
# Point to your own S3 bucket, GCS bucket, or HTTP server
# The mirror should have: models/, references/, atlases/ subdirectories
# DATA_MIRROR=https://your-bucket.s3.amazonaws.com/biochat-data
# DATA_MIRROR=gs://your-bucket/biochat-data
# DATA_MIRROR=/mnt/nfs/biochat-data

# App
FRONTEND_PORT=3000
BACKEND_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

# Control plane security
# Set this before exposing the web UI anywhere beyond your local machine.
CONTROL_API_TOKEN=
CONTROL_COOKIE_SECURE=false
ENABLE_DEV_ENDPOINTS=false
